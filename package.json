{
  "name": "transient-conduction-model",
  "version": "0.0.0",
  "description": "Demo m30ml project for conducting a transient heat transfer analysis",
  "author": "Sean Marquez",
  "license": "CC0-1.0",
  "packageManager": "npm",
  "files": [
    "model"
  ],
  "bin": {
    "transient-conduction": "./bin/transient-conduction.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/multiplanetaryhomestead/transient-conduction-model.git"
  },
  "workspaces": [
    "./packages/*",
    "./packages/@*/*"
  ],
  "dependencies": {
    "@rse/nunjucks-cli": "1.5.3",
    "yaml-datastore": "github:dof-initiative/yaml-datastore"
  },
  "m30pm": {
    "versionControlTool": "git",
    "buildTool": "gradle",
    "loggingLevel": "error"
  },
  "scripts": {
    "prepare": "./gradlew installPythonDependencies",
    "build": "npm run clean && ./gradlew --offline build",
    "clean": "./gradlew --offline clean",
    "readme": "nunjucks -d package.json views/README.md.njk > README.md"
  },
  "type": "module"
}
